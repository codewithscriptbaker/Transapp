TRANSLATION_PROVIDER=mymemory
# TRANSLATION_PROVIDER=nllb

MYMEMORY_API_URL=https://api.mymemory.translated.net/get
MYMEMORY_EMAIL=

STT_PROVIDER=groq
# STT_PROVIDER=whisper

GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1/audio/transcriptions
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# WHISPER_MODEL_NAME=openai/whisper-small
# WHISPER_DEVICE=cpu
# MAX_AUDIO_SIZE_MB=25

HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000

# Auth: auto | supabase | local
# auto — Supabase when configured below, otherwise SQLite local auth
AUTH_PROVIDER=auto

# Optional Supabase (leave empty to use local SQLite auth)
SUPABASE_URL=
SUPABASE_JWT_SECRET=

# Local auth (SQLite) — used when Supabase is not configured
SQLITE_DB_PATH=data/transapp.db
JWT_SECRET=change-me-use-a-long-random-secret-in-production
JWT_EXPIRE_HOURS=168
